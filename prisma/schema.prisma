// ============================================================
// SCHOLAR AI — AI-Integrated Scholarship Management System
// Prisma Schema (PostgreSQL)
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  APPLICANT
  REVIEWER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  PREFER_NOT_TO_SAY
}

enum DocumentType {
  PAYSLIP
  IC
  TRANSCRIPT
  OFFER_LETTER
  BIRTH_CERTIFICATE
  OTHER
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ScholarshipStatus {
  DRAFT
  OPEN
  CLOSED
  AWARDED
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
}

enum ReviewDecision {
  APPROVE
  REJECT
  REQUEST_MORE_INFO
}

enum NotificationType {
  APPLICATION_SUBMITTED
  APPLICATION_APPROVED
  APPLICATION_REJECTED
  DOCUMENT_VERIFIED
  DOCUMENT_REJECTED
  REVIEW_ASSIGNED
  GENERAL
}

// ============================================================
// 1. USER
// Core auth table. role controls which portal the user accesses.
// ============================================================

model User {
  id          Int       @id @default(autoincrement())
  fullname    String
  email       String    @unique
  password    String
  role        Role
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  applicantProfile    ApplicantProfile?
  reviewer            Reviewer?
  documents           Document[]
  managedScholarships Scholarship[]      @relation("ScholarshipCreator")
  verifiedDocuments   Document[]         @relation("DocumentVerifier")
  reviewAssignments   ReviewAssignment[]  @relation("AssignedBy")
  notifications       Notification[]
}

// ============================================================
// 2. APPLICANT PROFILE
// Extended personal, academic & financial data per applicant.
// One-to-one with User where role = APPLICANT.
// ============================================================

model ApplicantProfile {
  id     Int @id @default(autoincrement())
  userId Int @unique

  // Personal details
  dateOfBirth DateTime?
  icNumber    String?   @unique
  phone       String?
  address     String?
  gender      Gender?
  race        String?
  religion    String?

  // Academic info
  institution String?
  program     String?
  yearOfStudy Int?
  cgpa        Float?

  // Financial info
  householdIncome Float?
  numDependents   Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  dependents   Dependent[]
  applications Application[]
}

// ============================================================
// 3. DEPENDENT
// Family members listed under an applicant for financial review.
// ============================================================

model Dependent {
  id                 Int @id @default(autoincrement())
  applicantProfileId Int

  name          String
  relationship  String
  age           Int?
  occupation    String?
  monthlyIncome Float   @default(0)

  createdAt DateTime @default(now())

  // Relations
  applicantProfile ApplicantProfile @relation(fields: [applicantProfileId], references: [id], onDelete: Cascade)
}

// ============================================================
// 4. REVIEWER
// Extra metadata for users with role = REVIEWER.
// ============================================================

model Reviewer {
  id     Int @id @default(autoincrement())
  userId Int @unique

  specialization String?
  isActive       Boolean  @default(true)
  registeredAt   DateTime @default(now())

  // Relations
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments ReviewAssignment[]
}

// ============================================================
// 5. SCHOLARSHIP
// Created and managed by admin users.
// ============================================================

model Scholarship {
  id          Int @id @default(autoincrement())
  createdById Int

  title              String
  description        String?
  totalBudget        Float?
  amountPerRecipient Float?
  maxRecipients      Int?
  applicationStart   DateTime?
  applicationEnd     DateTime?
  status             ScholarshipStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  admin               User                 @relation("ScholarshipCreator", fields: [createdById], references: [id])
  eligibilityCriteria EligibilityCriteria?
  applications        Application[]
}

// ============================================================
// 6. ELIGIBILITY CRITERIA
// One set of rules per scholarship (1-to-1).
// ============================================================

model EligibilityCriteria {
  id            Int @id @default(autoincrement())
  scholarshipId Int @unique

  minCgpa            Float?
  maxHouseholdIncome Float?
  requiredRace       String?
  requiredGender     Gender?
  requiredProgram    String?
  maxYearOfStudy     Int?
  otherCriteria      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  scholarship Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
}

// ============================================================
// 7. APPLICATION
// An applicant's submission for a specific scholarship.
// ============================================================

model Application {
  id            Int               @id @default(autoincrement())
  scholarshipId Int
  applicantId   Int
  status        ApplicationStatus @default(DRAFT)
  submittedAt   DateTime?
  updatedAt     DateTime          @updatedAt

  // Relations
  scholarship   Scholarship        @relation(fields: [scholarshipId], references: [id])
  applicant     ApplicantProfile   @relation(fields: [applicantId], references: [id])
  documents     Document[]
  aiEvaluation  AiEvaluation?
  assignments   ReviewAssignment[]
  notifications Notification[]

  @@unique([scholarshipId, applicantId])
  @@index([scholarshipId])
  @@index([applicantId])
  @@index([status])
}

// ============================================================
// 8. DOCUMENT
// Uploaded files attached to a user / application.
// ============================================================

model Document {
  id            Int            @id @default(autoincrement())
  userId        Int
  applicationId Int?
  docType       DocumentType
  fileName      String
  fileUrl       String
  fileSizeKb    Int?
  status        DocumentStatus @default(PENDING)
  verifiedById  Int?
  verifiedAt    DateTime?
  uploadedAt    DateTime       @default(now())

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  verifier    User?        @relation("DocumentVerifier", fields: [verifiedById], references: [id])

  @@index([userId])
  @@index([applicationId])
  @@index([status])
}

// ============================================================
// 9. AI EVALUATION
// One AI-generated evaluation per application.
// Scores used by reviewers as decision support.
// ============================================================

model AiEvaluation {
  id            Int @id @default(autoincrement())
  applicationId Int @unique

  financialScore  Float?
  academicScore   Float?
  overallScore    Float?
  matchPercentage Float?

  aiSummary       String?
  recommendations String?
  modelVersion    String?

  evaluatedAt DateTime @default(now())

  // Relations
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([overallScore(sort: Desc)])
}

// ============================================================
// 10. REVIEW ASSIGNMENT
// Admin assigns a reviewer to an application.
// ============================================================

model ReviewAssignment {
  id            Int      @id @default(autoincrement())
  applicationId Int
  reviewerId    Int
  assignedById  Int?
  assignedAt    DateTime @default(now())

  // Relations
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  reviewer       Reviewer    @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  assignedByUser User?       @relation("AssignedBy", fields: [assignedById], references: [id])
  review         Review?

  @@unique([applicationId, reviewerId])
  @@index([reviewerId])
  @@index([applicationId])
}

// ============================================================
// 11. REVIEW
// Reviewer's formal decision and comments on an assignment.
// ============================================================

model Review {
  id           Int            @id @default(autoincrement())
  assignmentId Int            @unique
  decision     ReviewDecision
  comments     String?
  reviewedAt   DateTime       @default(now())

  // Relations
  assignment ReviewAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

// ============================================================
// 12. NOTIFICATION
// Automated messages sent to users on key status changes.
// ============================================================

model Notification {
  id            Int              @id @default(autoincrement())
  userId        Int
  applicationId Int?
  type          NotificationType
  message       String
  isRead        Boolean          @default(false)
  sentAt        DateTime         @default(now())

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, isRead])
}
